# OneCapture e-Claim — copy to .env and fill in real values.

# SQLAlchemy URLs (psycopg 3 driver). The test DB must be a SEPARATE database;
# the test suite creates/drops the schema in it.
DATABASE_URL=postgresql+psycopg://onecapture:onecapture@localhost:5432/onecapture
TEST_DATABASE_URL=postgresql+psycopg://onecapture:onecapture@localhost:5432/onecapture_test

# Only needed for LIVE OCR. Tests mock the provider and never read this.
ANTHROPIC_API_KEY=

# Carbon spend-based fallback factor (kgCO2e per unit currency) — demo D14.
SPEND_FACTOR=0.35

# Local image store (object storage is a deferred seam).
IMAGE_DIR=data/eclaim_images
